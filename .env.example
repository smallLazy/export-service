APP_ENV=local
APP_ADDR=:8088

# =========================== 导出配置 ===========================
# 导出文件保存目录
EXPORT_OUTPUT_DIR=./exports
# 单个导出任务/查询的超时时间
EXPORT_QUERY_TIMEOUT=5m
# MySQL 分页导出每批拉取最大游标数
EXPORT_MYSQL_BATCH_SIZE=1000
# 启用内存 mock 数据数，主要用于本地测试
EXPORT_SEED_SIZE=30000
# 是否使用内存模拟数据启动服务，生产环境 false
EXPORT_USE_MEMORY_WHEN_NO_DB=true
# 最多同时跑几个导出任务
EXPORT_MAX_CONCURRENCY=3
# 导出失败后最多自动重试几次
EXPORT_MAX_RETRIES=2
# =========================== 导出配置 ===========================

# =========================== 数据库配置 ===========================
# MySQL 地址
DB_HOST=127.0.0.1
# MySQL 端口
DB_PORT=3306
# trade 数据库
TRADE_DB_DATABASE=
# MySQL 用户名
DB_USERNAME=
# MySQL 密码
DB_PASSWORD=
# MySQL 字符集
DB_CHARSET=utf8mb4
# 是否把时间字段解析成 Go 的 time.Time
DB_PARSE_TIME=true
# 时区
DB_LOC=Local
# 表前缀
DB_PREFIX=h_
# 数据库连接池最大打开连接数
DB_MAX_OPEN_CONNS=10
# 数据库连接池最大空闲连接数
DB_MAX_IDLE_CONNS=5
# =========================== 数据库配置 ===========================


# ======================== OSS 配置 ========================
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BASE_PATH=
OSS_URL_EXPIRE_DAYS=
EXPORT_OSS_MAX_RETRIES=
# ======================== OSS 配置 ========================

